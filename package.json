{
  "name": "demo",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/cds-types": "^0.12.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": ">=8",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "node --test"
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "cds": {
    "requires": {
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        },
        "db": {
          "kind": "hana",
          "model": [
            "db/schema.cds"
          ]
        },
        "messaging": {
          "kind": "enterprise-messaging",
          "format": "cloudevents"
        }
      },
      "[development]": {
        "auth": {
          "kind": "mocked"
        },
        "db": {
          "kind": "sqlite",
          "model": [
            "db/schema.cds"
          ]
        },
        "messaging": {
          "kind": "local-messaging"
        }
      }
    }
  }
}
